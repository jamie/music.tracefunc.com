---
layout: default
title: Home
---

<h2>Books</h2>

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-3 mb-4">
  <% collections.books.resources.each do |book| %>
    <div class="col">
      <div class="card h-100">
        <a href="<%= book.relative_url %>">
          <img src="<%= book.data.cover_image %>" class="card-img-top" alt="<%= book.data.title %>">
        </a>
        <div class="card-body">
          <h5 class="card-title mb-0">
            <a href="<%= book.relative_url %>" class="text-decoration-none stretched-link"><%= book.data.title %></a>
          </h5>
        </div>
        <div class="card-footer text-muted">
          <%= book.data.songs.size %> songs
        </div>
      </div>
    </div>
  <% end %>
</div>

<h2>Media</h2>

<ul class="list-group mb-4">
  <% collections.games.resources.each do |game| %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <a href="<%= game.relative_url %>"><%= game.data.title %></a>
      <span class="badge bg-secondary rounded-pill"><%= game.data.songs.size %></span>
    </li>
  <% end %>
</ul>

<%
  other_songs = collections.songs.resources.reject { |s| s.data.book || s.data.game }
%>
<% if other_songs.any? %>
<h2>Other Songs</h2>

<ul class="list-group">
  <% other_songs.each do |song| %>
    <li class="list-group-item">
      <a href="<%= song.relative_url %>"><%= song.data.title %></a>
    </li>
  <% end %>
</ul>
<% end %>

<h2><a href="/reference">Links &amp; Reference</a></h2>
