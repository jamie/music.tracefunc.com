---
layout: default
---

<nav>
  <a href="/">Home</a>
  {% if page.data.game_url %} &bull; <a href="{{ page.data.game_url }}">{{ page.data.game }}</a>{% endif %}
  {% if page.data.book_url %} &bull; <a href="{{ page.data.book_url }}">{{ page.data.book }}</a>{% endif %}
</nav>

{{ content }}

<div class="abc-player-bar" id="abc-player-bar">
  <div class="abc-player-bar__audio audio abcjs" id="page-audio"></div>
  <div class="abc-player-bar__controls">
    <label class="abc-player-bar__control">
      <span>Transpose</span>
      <select id="transpose-select"></select>
    </label>
    <label class="abc-player-bar__control abc-player-bar__control--checkbox" for="tablature-toggle">
      <input type="checkbox" id="tablature-toggle">
      <span>Tablature</span>
    </label>
  </div>
</div>
