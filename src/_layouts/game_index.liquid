---
layout: default
---

<nav><a href="/">Home</a></nav>

<h1>{{ page.data.title }}</h1>

{% assign has_books = false %}
{% for song in page.data.songs %}
  {% if song.book != "" and song.book != nil %}
    {% assign has_books = true %}
  {% endif %}
{% endfor %}

<table class="table table-hover">
  <thead>
    <tr>
      <th>#</th>
      <th>Title</th>
      {% if has_books %}<th>Book</th>{% endif %}
    </tr>
  </thead>
  <tbody>
    {% for song in page.data.songs %}
      <tr>
        <td class="text-muted">{{ song.x }}</td>
        <td><a href="{{ song.url }}">{{ song.title }}</a></td>
        {% if has_books %}<td class="text-muted">{{ song.book }}</td>{% endif %}
      </tr>
    {% endfor %}
  </tbody>
</table>
