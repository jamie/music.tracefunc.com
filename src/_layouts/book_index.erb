---
layout: default
---

<nav><a href="/">Home</a></nav>

<div class="d-flex gap-4 align-items-start mb-4">
  <div style="flex: 0 0 250px;">
    <img src="<%= resource.data.cover_image %>" class="img-fluid rounded" alt="<%= resource.data.title %>">
  </div>
  <div>
    <h1><%= resource.data.title %></h1>
    <div><%= yield %></div>
  </div>
</div>

<% has_sources = resource.data.songs.any? { |s| !s["game"].to_s.empty? } %>

<table class="table table-hover">
  <thead>
    <tr>
      <th>#</th>
      <th></th>
      <th>Title</th>
      <% if has_sources %><th>Source</th><% end %>
    </tr>
  </thead>
  <tbody>
    <% resource.data.songs.each do |song| %>
      <tr>
        <td class="text-muted"><%= song["track"] %></td>
        <td><img src="/images/<%= song["instrument"] %>.svg" width="20" height="20" alt="<%= song["instrument"] %>"></td>
        <td><a href="<%= song["url"] %>"><%= song["title"] %></a></td>
        <% if has_sources %><td class="text-muted"><%= song["game"] %></td><% end %>
      </tr>
    <% end %>
  </tbody>
</table>
